# Root gitignore to handle monorepo paths

# Dependency directories at any level
**/node_modules/

# Production build outputs at any level
**/dist/
**/build/

# Local environment variables
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Log files
**/*.log
**/npm-debug.log*

# OS files
.DS_Store
Thumbs.db
